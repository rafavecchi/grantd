# --- Database (Supabase or any Postgres) ---
# Supabase: Project Settings -> Database -> Connection string -> URI (use the pooler for serverless)
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# --- Encryption keyring (envelope encryption with key versioning) ---
# Generate with:  npm run keygen
# JSON map of key-id -> base64-encoded 32-byte key. New writes use ENCRYPTION_ACTIVE_KID;
# old rows keep decrypting under their original key id. Add a new id to rotate.
ENCRYPTION_KEYRING={"1":"REPLACE_WITH_BASE64_32_BYTE_KEY"}
ENCRYPTION_ACTIVE_KID=1

# Stable pepper for hashing API keys at rest (do not change once keys are issued).
API_KEY_SALT=REPLACE_WITH_A_LONG_RANDOM_STRING

# --- Server ---
# Public base URL of this broker; OAuth redirect URIs are derived from it.
PUBLIC_BASE_URL=http://localhost:8787
PORT=8787
