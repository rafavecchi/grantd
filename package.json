{
  "name": "grantd",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "OAuth-for-agents: a dead-simple, MCP-native OAuth token broker that lets AI agents act on a user's behalf.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx scripts/migrate.ts",
    "keygen": "tsx scripts/keygen.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "mcp": "tsx src/mcp.ts",
    "mcp:test": "tsx scripts/mcp-test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
